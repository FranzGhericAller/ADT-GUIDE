#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct {
    char name[50];
    int age;
} Person;

typedef struct Node {
    Person data;
    struct Node* next;
} Node;

typedef struct {
    Node* head;
    int count;
} List;

List* initialize() {
    List* list = (List*)malloc(sizeof(List));
    if (list != NULL) {
        list->head = NULL;
        list->count = 0;
    }
    return list;
}

void empty(List* list) {
    if (!list) return;
    Node* current = list->head;
    while (current != NULL) {
        Node* temp = current;
        current = current->next;
        free(temp);
    }
    list->head = NULL;
    list->count = 0;
}

void insertFirst(List* list, Person data) {
    if (!list) return;
    Node* newNode = (Node*)malloc(sizeof(Node));
    if (!newNode) return;

    newNode->data = data;
    newNode->next = list->head;
    list->head = newNode;
    list->count++;
}

void insertLast(List* list, Person data) {
    if (!list) return;
    Node* newNode = (Node*)malloc(sizeof(Node));
    if (!newNode) return;

    newNode->data = data;
    newNode->next = NULL;

    if (list->head == NULL) {
        list->head = newNode;
    } else {
        Node* current = list->head;
        while (current->next != NULL)
            current = current->next;
        current->next = newNode;
    }
    list->count++;
}

void insertPos(List* list, Person data, int index) {
    if (!list || index < 0 || index > list->count) return;

    if (index == 0) {
        insertFirst(list, data);
    } else if (index == list->count) {
        insertLast(list, data);
    } else {
        Node* newNode = (Node*)malloc(sizeof(Node));
        if (!newNode) return;
        newNode->data = data;

        Node* current = list->head;
        for (int i = 0; i < index - 1; i++)
            current = current->next;

        newNode->next = current->next;
        current->next = newNode;
        list->count++;
    }
}

void deleteStart(List* list) {
    if (!list || list->head == NULL) return;
    Node* temp = list->head;
    list->head = temp->next;
    free(temp);
    list->count--;
}

void deleteLast(List* list) {
    if (!list || list->head == NULL) return;

    if (list->count == 1) {
        free(list->head);
        list->head = NULL;
    } else {
        Node* current = list->head;
        for (int i = 0; i < list->count - 2; i++)
            current = current->next;
        free(current->next);
        current->next = NULL;
    }
    list->count--;
}

void deletePos(List* list, int index) {
    if (!list || index < 0 || index >= list->count) return;

    if (index == 0) {
        deleteStart(list);
    } else {
        Node* current = list->head;
        for (int i = 0; i < index - 1; i++)
            current = current->next;

        Node* temp = current->next;
        current->next = temp->next;
        free(temp);
        list->count--;
    }
}

Person retrieve(List* list, int index) {
    Person emptyPerson = {"", -1};
    if (!list || index < 0 || index >= list->count) return emptyPerson;

    Node* current = list->head;
    for (int i = 0; i < index; i++)
        current = current->next;

    return current->data;
}

int locate(List* list, char name[]) {
    if (!list || list->head == NULL) return -1;

    Node* current = list->head;
    int index = 0;
    while (current != NULL) {
        if (strcmp(current->data.name, name) == 0)
            return index;
        current = current->next;
        index++;
    }
    return -1;
}

void display(List* list) {
    if (!list || list->head == NULL) {
        printf("List is empty.\n");
        return;
    }
    Node* current = list->head;
    while (current != NULL) {
        printf("Name: %s, Age: %d -> ", current->data.name, current->data.age);
        current = current->next;
    }
    printf("NULL\n");
}

int main() {
    List* myList = initialize();

    Person p1 = {"Alice", 25};
    Person p2 = {"Bob", 30};
    Person p3 = {"Charlie", 22};
    Person p4 = {"Diana", 28};

    insertFirst(myList, p1);  
    insertLast(myList, p2);  
    insertPos(myList, p3, 1); 
    insertPos(myList, p4, 2); 

    display(myList);

    printf("Index of Bob: %d\n", locate(myList, "Bob"));

    deleteStart(myList); 
    deleteLast(myList);  
    deletePos(myList, 1); 

    display(myList);

    empty(myList); 
    display(myList);

    free(myList); 

    return 0;
}
