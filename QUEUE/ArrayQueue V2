#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>

#define MAX 100

typedef struct {
    char name[50];
    int age;
} Person;

typedef struct {
    Person data[MAX];
    int front;
    int rear;
} Queue;

Queue* initialize() {
    Queue* Q = (Queue*)malloc(sizeof(Queue));
    if (Q != NULL) {
        Q->front = 1;
        Q->rear = 0;
    }
    return Q;
}

bool isEmpty(Queue* Q) {
    if (!Q) return true;
    return (Q->front == (Q->rear + 1) % MAX);
}

bool isFull(Queue* Q) {
    if (!Q) return false;
    return (Q->front == (Q->rear + 2) % MAX);
}

int enqueue(Queue* Q, Person p) {
    if (!Q || isFull(Q)) {
        printf("Queue is full. Cannot enqueue %s.\n", p.name);
        return 0;
    }

    Q->rear = (Q->rear + 1) % MAX;
    Q->data[Q->rear] = p;

    printf("%s added to queue.\n", p.name);
    return 1;
}

Person dequeue(Queue* Q) {
    Person emptyPerson = {"", -1};

    if (!Q || isEmpty(Q)) {
        printf("Queue is empty. Cannot dequeue.\n");
        return emptyPerson;
    }

    Person frontPerson = Q->data[Q->front];
    Q->front = (Q->front + 1) % MAX;

    return frontPerson;
}

Person front(Queue* Q) {
    Person emptyPerson = {"", -1};

    if (!Q || isEmpty(Q)) {
        printf("Queue is empty.\n");
        return emptyPerson;
    }

    return Q->data[Q->front];
}

void display(Queue* Q) {
    if (!Q || isEmpty(Q)) {
        printf("Queue is empty.\n");
        return;
    }

    printf("\nQueue (front -> rear):\n");

    int i = Q->front;

    while (true) {
        printf("Name: %s | Age: %d\n", Q->data[i].name, Q->data[i].age);

        if (i == Q->rear)
            break;

        i = (i + 1) % MAX;
    }
}

int main() {

    Queue* Q = initialize();
    int choice;
    Person p;

    do {

        printf("\n===== QUEUE MENU =====\n");
        printf("1. Enqueue\n");
        printf("2. Dequeue\n");
        printf("3. View Front\n");
        printf("4. Display Queue\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {

        case 1:
            printf("Enter name: ");
            scanf("%s", p.name);

            printf("Enter age: ");
            scanf("%d", &p.age);

            enqueue(Q, p);
            break;

        case 2: {
            Person removed = dequeue(Q);
            if (removed.age != -1)
                printf("Dequeued: %s %d\n", removed.name, removed.age);
            break;
        }

        case 3: {
            Person f = front(Q);
            if (f.age != -1)
                printf("Front: %s %d\n", f.name, f.age);
            break;
        }

        case 4:
            display(Q);
            break;

        case 5:
            printf("Exiting program...\n");
            break;

        default:
            printf("Invalid choice.\n");
        }

    } while(choice != 5);

    free(Q);
    return 0;
}
