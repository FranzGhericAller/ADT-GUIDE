#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>

typedef struct {
    char name[50];
    int age;
} Person;

typedef struct Node {
    Person data;
    struct Node* next;
} Node;

typedef struct {
    Node* front;
    Node* rear;
} Queue;

Queue* initialize() {
    Queue* Q = (Queue*)malloc(sizeof(Queue));
    if (Q != NULL) {
        Q->front = NULL;
        Q->rear = NULL;
    }
    return Q;
}

bool isFull(Queue* Q) {
    return false;
}

bool isEmpty(Queue* Q) {
    if (!Q || Q->front == NULL) return true;
    return false;
}

int enqueue(Queue* Q, Person p) {
    if (!Q) return 0;

    Node* newNode = (Node*)malloc(sizeof(Node));
    if (!newNode) return 0;

    newNode->data = p;
    newNode->next = NULL;

    if (isEmpty(Q)) {
        Q->front = newNode;
        Q->rear = newNode;
    } else {
        Q->rear->next = newNode;
        Q->rear = newNode;
    }

    printf("%s added to queue.\n", p.name);
    return 1;
}

Person dequeue(Queue* Q) {
    Person emptyPerson = {"", -1};

    if (!Q || isEmpty(Q)) {
        printf("Queue is empty.\n");
        return emptyPerson;
    }

    Node* temp = Q->front;
    Person frontPerson = temp->data;

    Q->front = Q->front->next;

    if (Q->front == NULL)
        Q->rear = NULL;

    free(temp);

    return frontPerson;
}

Person front(Queue* Q) {
    Person emptyPerson = {"", -1};

    if (!Q || isEmpty(Q)) {
        printf("Queue is empty.\n");
        return emptyPerson;
    }

    return Q->front->data;
}

void display(Queue* Q) {
    if (!Q || isEmpty(Q)) {
        printf("Queue is empty.\n");
        return;
    }

    Node* current = Q->front;

    printf("\nQueue (front -> rear):\n");

    while (current != NULL) {
        printf("Name: %s | Age: %d\n", current->data.name, current->data.age);
        current = current->next;
    }
}

int main() {

    Queue* Q = initialize();
    int choice;
    Person p;

    do {

        printf("\n===== LINKED QUEUE MENU =====\n");
        printf("1. Enqueue\n");
        printf("2. Dequeue\n");
        printf("3. View Front\n");
        printf("4. Display Queue\n");
        printf("5. Exit\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice) {

        case 1:
            printf("Enter name: ");
            scanf("%s", p.name);

            printf("Enter age: ");
            scanf("%d", &p.age);

            enqueue(Q, p);
            break;

        case 2: {
            Person removed = dequeue(Q);
            if (removed.age != -1)
                printf("Dequeued: %s %d\n", removed.name, removed.age);
            break;
        }

        case 3: {
            Person f = front(Q);
            if (f.age != -1)
                printf("Front: %s %d\n", f.name, f.age);
            break;
        }

        case 4:
            display(Q);
            break;

        case 5:
            printf("Exiting program...\n");
            break;

        default:
            printf("Invalid choice.\n");
        }

    } while(choice != 5);

    while (!isEmpty(Q)) {
        dequeue(Q);
    }

    free(Q);

    return 0;
}
